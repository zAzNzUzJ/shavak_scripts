#!/bin/bash
# =============================================================================
# HPC Setup Script
# Tasks: kernel packages, NVIDIA driver, /home/apps dir, admin user, spack,
#        and shavak_hpc_installer clone
# Run as root:  sudo bash hpc_setup.sh
# =============================================================================

set -euo pipefail

# ---------- colour helpers ---------------------------------------------------
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
info()    { echo -e "${GREEN}[INFO]${NC}  $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC}  $*"; }
error()   { echo -e "${RED}[ERROR]${NC} $*"; exit 1; }

# ---------- root check -------------------------------------------------------
[[ $EUID -ne 0 ]] && error "Please run this script as root (sudo bash $0)"

# =============================================================================
# 1. Download kernel packages matching the running kernel
# =============================================================================


dnf install -y   kernel*$(uname -r)


# =============================================================================
# 2. Download NVIDIA driver
# =============================================================================
NVIDIA_URL="https://us.download.nvidia.com/XFree86/Linux-x86_64/580.142/NVIDIA-Linux-x86_64-580.142.run"
NVIDIA_FILE="${HOME}/Downloads/NVIDIA-Linux-x86_64-580.142.run"

info "Downloading NVIDIA driver..."

if command -v wget &>/dev/null; then
    wget -c -O "${NVIDIA_FILE}" "${NVIDIA_URL}"
elif command -v curl &>/dev/null; then
    curl -L -C - -o "${NVIDIA_FILE}" "${NVIDIA_URL}"
else
    error "Neither wget nor curl found. Please install one and re-run."
fi

chmod +x "${NVIDIA_FILE}"
info "NVIDIA driver saved to: ${NVIDIA_FILE}"

# =============================================================================
# 3. Create /home/apps directory
# =============================================================================
info "Creating /home/apps directory..."
mkdir -p /home/apps
info "/home/apps created."

# =============================================================================
# 4. Create user 'admin' with password 'admin'
# =============================================================================
if id "admin" &>/dev/null; then
    warn "User 'admin' already exists — skipping creation."
else
    info "Creating user 'admin'..."
    useradd -m -s /bin/bash admin
    echo "admin:admin" | chpasswd
    info "User 'admin' created with password 'admin'."
fi

# =============================================================================
# 5. Change ownership of /home/apps to admin:admin
# =============================================================================
info "Setting ownership of /home/apps to admin:admin..."
chown -R admin:admin /home/apps
info "Ownership set."

# =============================================================================
# 6. Git clone Spack into /home/apps/
# =============================================================================
if [[ -d /home/apps/spack ]]; then
    warn "Spack directory already exists at /home/apps/spack — skipping clone."
else
    info "Cloning Spack into /home/apps/spack ..."
    sudo -u admin git clone -c feature.manyFiles=true --depth=2 --branch/v1.1 https://github.com/spack/spack.git
    info "Spack cloned successfully."
fi

# =============================================================================
# 7. Git clone shavak_hpc_installer into /home/apps/
# =============================================================================
INSTALLER_DIR="/home/apps/shavak_hpc_installer"
if [[ -d "${INSTALLER_DIR}" ]]; then
    warn "shavak_hpc_installer already exists at ${INSTALLER_DIR} — skipping clone."
else
    info "Cloning shavak_hpc_installer into ${INSTALLER_DIR} ..."
    sudo -u admin git clone \
        https://github.com/Sanket5153/shavak_hpc_installer/ \
        "${INSTALLER_DIR}"
    info "shavak_hpc_installer cloned successfully."
fi

# =============================================================================
# Summary
# =============================================================================
echo ""
echo -e "${GREEN}======================================================${NC}"
echo -e "${GREEN}  HPC Setup Complete!${NC}"
echo -e "${GREEN}======================================================${NC}"
echo -e "  Kernel packages   : ${HOME}/Downloads/"
echo -e "  NVIDIA driver     : ${NVIDIA_FILE}"
echo -e "  /home/apps owner  : admin:admin"
echo -e "  Spack             : /home/apps/spack"
echo -e "  HPC Installer     : ${INSTALLER_DIR}"
echo ""
warn "IMPORTANT: Password 'admin' is insecure. Change it after first login:"
echo -e "  passwd admin"
echo ""
info "To install the NVIDIA driver (after disabling Nouveau), run:"
echo -e "  sudo bash ${NVIDIA_FILE}"
echo ""
